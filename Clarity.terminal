<plist version="1.0">
<dict>
	<key>name</key>
	<string>Clarity</string>
	<key>type</key>
	<string>Window Settings</string>

	<!-- Launch clarity-terminal on open -->
	<key>CommandString</key>
	<string>clarity-terminal</string>
	<key>RunCommandAsShell</key>
	<false/>

	<!-- Font: Menlo 14pt (ships with every Mac) -->
